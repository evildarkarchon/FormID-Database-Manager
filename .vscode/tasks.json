{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/FormID Database Manager.slnx",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/FormID Database Manager.WinUI/FormID Database Manager.WinUI.csproj",
                "-c",
                "Release",
                "-p:Platform=x64",
                "-r",
                "win-x64",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/FormID Database Manager.WinUI/FormID Database Manager.WinUI.csproj",
                "--property:Platform=x64",
                "--property:WindowsPackageType=None",
                "--property:WindowsAppSDKSelfContained=true"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}