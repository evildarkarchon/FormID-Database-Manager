{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/FormID Database Manager.slnx",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "pwsh",
            "type": "process",
            "args": [
                "${workspaceFolder}/scripts/publish-portable.ps1"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/FormID Database Manager.WinUI/FormID Database Manager.WinUI.csproj",
                "--property:Platform=x64"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
