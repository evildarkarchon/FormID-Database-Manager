<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="FormID_Database_Manager.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FormID_Database_Manager.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <Thickness x:Key="WindowContentMargin">16</Thickness>
            <Thickness x:Key="FieldRowMargin">0,0,0,8</Thickness>
            <Thickness x:Key="PanelSpacingMargin">0,12,0,0</Thickness>

            <Style x:Key="FieldLabelTextBlockStyle" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,12,0" />
            </Style>

            <Style x:Key="PathTextBoxStyle" TargetType="TextBox">
                <Setter Property="MinWidth" Value="320" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
            </Style>

            <Style x:Key="WorkflowButtonStyle" TargetType="Button">
                <Setter Property="MinWidth" Value="120" />
                <Setter Property="HorizontalAlignment" Value="Right" />
            </Style>

            <Style x:Key="PluginListBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="4" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
