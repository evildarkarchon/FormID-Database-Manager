<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="FormID_Database_Manager.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Phase 10 verification widths: wide 1100 px, medium 800 px, narrow 640 px. -->
            <x:Double x:Key="Phase10WideWidth">1100</x:Double>
            <x:Double x:Key="Phase10MediumWidth">800</x:Double>
            <x:Double x:Key="Phase10NarrowWidth">640</x:Double>
            <x:Double x:Key="PluginListMinHeight">120</x:Double>

            <Thickness x:Key="WindowContentMargin">16</Thickness>
            <Thickness x:Key="FieldRowMargin">0,0,0,8</Thickness>
            <Thickness x:Key="PanelSpacingMargin">0,12,0,0</Thickness>

            <Style x:Key="FieldLabelTextBlockStyle" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
            </Style>

            <Style x:Key="PathTextBoxStyle" TargetType="TextBox">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            </Style>

            <Style x:Key="WorkflowButtonStyle" TargetType="Button">
                <Setter Property="MinWidth" Value="132" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="12,6" />
            </Style>

            <Style x:Key="PrimaryWorkflowButtonStyle" TargetType="Button" BasedOn="{StaticResource WorkflowButtonStyle}">
                <Setter Property="MinWidth" Value="148" />
            </Style>

            <Style x:Key="PluginListBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="4" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
