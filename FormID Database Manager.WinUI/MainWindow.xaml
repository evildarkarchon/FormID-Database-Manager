<?xml version="1.0" encoding="UTF-8" ?>
<Window
    x:Class="FormID_Database_Manager.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="FormID Database Manager"
    mc:Ignorable="d">

    <Border
        x:Name="Root"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        Padding="{StaticResource WindowContentMargin}">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto" RowSpacing="10">
            <StackPanel Grid.Row="0" Spacing="2">
                <TextBlock
                    FontSize="22"
                    FontWeight="SemiBold"
                    Text="FormID Database Manager"
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Build SQLite FormID lookup databases from Bethesda plugin data."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Grid
                Grid.Row="1"
                ColumnDefinitions="136,*,Auto"
                ColumnSpacing="8"
                RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                RowSpacing="6">
                <TextBlock
                    x:Name="GameLabel"
                    Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource FieldLabelTextBlockStyle}"
                    Text="Game" />
                <ComboBox
                    AutomationProperties.AutomationId="GameComboBox"
                    Grid.Row="0"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    AutomationProperties.HelpText="Select the Bethesda game release used for plugin parsing."
                    AutomationProperties.LabeledBy="{Binding ElementName=GameLabel}"
                    HorizontalAlignment="Stretch"
                    ItemsSource="{Binding AvailableGames}"
                    PlaceholderText="Select a game"
                    SelectedItem="{Binding SelectedGame, Mode=OneWay}"
                    SelectionChanged="GameComboBox_SelectionChanged"
                    TabIndex="0" />

                <TextBlock
                    x:Name="GameDirectoryLabel"
                    Grid.Row="1"
                    Grid.Column="0"
                    Style="{StaticResource FieldLabelTextBlockStyle}"
                    Text="Game Directory" />
                <Grid
                    Grid.Row="1"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    ColumnDefinitions="2*,*,Auto"
                    ColumnSpacing="8">
                    <TextBox
                        AutomationProperties.AutomationId="GameDirectoryTextBox"
                        AutomationProperties.HelpText="Selected game installation or data directory."
                        AutomationProperties.LabeledBy="{Binding ElementName=GameDirectoryLabel}"
                        IsReadOnly="True"
                        Style="{StaticResource PathTextBoxStyle}"
                        TabIndex="1"
                        Text="{Binding GameDirectory, Mode=OneWay}" />
                    <ComboBox
                        AutomationProperties.AutomationId="DirectoryComboBox"
                        Grid.Column="1"
                        AutomationProperties.HelpText="Choose from installed directories detected for the selected game."
                        AutomationProperties.Name="Detected installed directory"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{Binding DetectedDirectories}"
                        MinWidth="0"
                        PlaceholderText="Detected directories"
                        SelectedItem="{Binding GameDirectory, Mode=OneWay}"
                        SelectionChanged="DirectoryComboBox_SelectionChanged"
                        TabIndex="2" />
                    <Button
                        AutomationProperties.AutomationId="BrowseDirectoryButton"
                        Grid.Column="2"
                        AccessKey="B"
                        AutomationProperties.HelpText="Open a folder picker for a game installation or data directory."
                        Click="BrowseDirectory_Click"
                        Content="Browse..."
                        Style="{StaticResource WorkflowButtonStyle}"
                        TabIndex="3" />
                </Grid>

                <TextBlock
                    x:Name="DatabasePathLabel"
                    Grid.Row="2"
                    Grid.Column="0"
                    Style="{StaticResource FieldLabelTextBlockStyle}"
                    Text="Database File" />
                <TextBox
                    AutomationProperties.AutomationId="DatabasePathTextBox"
                    Grid.Row="2"
                    Grid.Column="1"
                    AutomationProperties.HelpText="SQLite database file to create or update."
                    AutomationProperties.LabeledBy="{Binding ElementName=DatabasePathLabel}"
                    IsReadOnly="True"
                    Style="{StaticResource PathTextBoxStyle}"
                    TabIndex="4"
                    Text="{Binding DatabasePath, Mode=TwoWay}" />
                <Button
                    AutomationProperties.AutomationId="SelectDatabaseButton"
                    Grid.Row="2"
                    Grid.Column="2"
                    AccessKey="D"
                    AutomationProperties.HelpText="Choose the SQLite database file."
                    Click="OnSelectDatabase_Click"
                    Content="Select Database"
                    Style="{StaticResource WorkflowButtonStyle}"
                    TabIndex="5" />

                <TextBlock
                    x:Name="FormIdListPathLabel"
                    Grid.Row="3"
                    Grid.Column="0"
                    Style="{StaticResource FieldLabelTextBlockStyle}"
                    Text="FormID List File" />
                <TextBox
                    AutomationProperties.AutomationId="FormIdListPathTextBox"
                    Grid.Row="3"
                    Grid.Column="1"
                    AutomationProperties.HelpText="Optional pipe-delimited FormID text file to import instead of scanning selected plugins."
                    AutomationProperties.LabeledBy="{Binding ElementName=FormIdListPathLabel}"
                    IsReadOnly="True"
                    Style="{StaticResource PathTextBoxStyle}"
                    TabIndex="6"
                    Text="{Binding FormIdListPath, Mode=TwoWay}" />
                <Button
                    AutomationProperties.AutomationId="SelectListFileButton"
                    Grid.Row="3"
                    Grid.Column="2"
                    AccessKey="L"
                    AutomationProperties.HelpText="Choose an optional FormID text file."
                    Click="OnSelectFormIdList_Click"
                    Content="Select List File"
                    Style="{StaticResource WorkflowButtonStyle}"
                    TabIndex="7" />

                <TextBlock
                    x:Name="PluginFilterLabel"
                    Grid.Row="4"
                    Grid.Column="0"
                    Style="{StaticResource FieldLabelTextBlockStyle}"
                    Text="Filter Plugins" />
                <TextBox
                    AutomationProperties.AutomationId="PluginFilterTextBox"
                    Grid.Row="4"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    AutomationProperties.HelpText="Filter the plugin list by plugin name."
                    AutomationProperties.LabeledBy="{Binding ElementName=PluginFilterLabel}"
                    PlaceholderText="Type to filter plugins"
                    TabIndex="8"
                    Text="{Binding PluginFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <Grid
                Grid.Row="2"
                MinHeight="{StaticResource PluginListMinHeight}"
                RowDefinitions="Auto,*"
                RowSpacing="6">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock
                        Style="{StaticResource FieldLabelTextBlockStyle}"
                        Text="Plugins" />
                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            AutomationProperties.AutomationId="SelectAllButton"
                            AccessKey="A"
                            Click="SelectAll_Click"
                            Content="Select All"
                            Style="{StaticResource WorkflowButtonStyle}"
                            TabIndex="10" />
                        <Button
                            AutomationProperties.AutomationId="SelectNoneButton"
                            AccessKey="N"
                            Click="SelectNone_Click"
                            Content="Select None"
                            Style="{StaticResource WorkflowButtonStyle}"
                            TabIndex="11" />
                    </StackPanel>
                </Grid>

                <Border
                    Grid.Row="1"
                    Style="{StaticResource PluginListBorderStyle}">
                    <ListView
                        AutomationProperties.AutomationId="PluginList"
                        AutomationProperties.HelpText="Use the arrow keys to move through plugins and Space to toggle a plugin checkbox."
                        AutomationProperties.Name="Plugin selection list"
                        ItemsSource="{Binding FilteredPlugins}"
                        SelectionMode="None"
                        TabIndex="9">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <CheckBox
                                    AutomationProperties.Name="{Binding Name}"
                                    Click="PluginCheckBox_Click"
                                    Content="{Binding Name}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    IsChecked="{Binding IsSelected, Mode=OneWay}"
                                    Margin="4,2">
                                    <CheckBox.ContentTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Text="{Binding}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="NoWrap" />
                                        </DataTemplate>
                                    </CheckBox.ContentTemplate>
                                </CheckBox>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </Grid>

            <StackPanel
                Grid.Row="3"
                Orientation="Horizontal"
                Spacing="16">
                <CheckBox
                    AutomationProperties.AutomationId="UpdateModeCheckBox"
                    AutomationProperties.HelpText="Replace existing database entries for matching FormIDs."
                    Content="Update Mode (replaces existing entries)"
                    IsChecked="{Binding UpdateMode, Mode=TwoWay}"
                    TabIndex="12" />
                <CheckBox
                    AutomationProperties.AutomationId="AdvancedModeCheckBox"
                    AutomationProperties.HelpText="Include base game and DLC plugins in the plugin list."
                    Click="AdvancedModeCheckBox_Click"
                    Content="Show Base Game/DLC Files"
                    IsChecked="{Binding AdvancedMode, Mode=OneWay}"
                    TabIndex="13" />
            </StackPanel>

            <Grid
                Grid.Row="4"
                ColumnDefinitions="*,Auto"
                ColumnSpacing="12"
                RowDefinitions="Auto,Auto"
                RowSpacing="6">
                <TextBlock
                    AutomationProperties.AutomationId="ProgressStatusTextBlock"
                    Grid.Row="0"
                    Grid.Column="0"
                    AutomationProperties.Name="Processing status"
                    Text="{Binding ProgressStatus, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
                <ProgressBar
                    AutomationProperties.AutomationId="ProcessingProgressBar"
                    Grid.Row="1"
                    Grid.Column="0"
                    AutomationProperties.HelpText="Shows current processing progress from zero to one hundred percent."
                    AutomationProperties.Name="Processing progress"
                    Maximum="100"
                    Minimum="0"
                    Value="{Binding ProgressValue, Mode=OneWay}" />
                <Button
                    AutomationProperties.AutomationId="ProcessFormIdsButton"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="1"
                    AccessKey="P"
                    Click="ProcessFormIds_Click"
                    Content="{Binding ProcessButtonText, Mode=OneWay}"
                    Style="{StaticResource PrimaryWorkflowButtonStyle}"
                    TabIndex="14" />
            </Grid>

            <StackPanel Grid.Row="5" Margin="0,0,0,4" Spacing="8">
                <InfoBar
                    AutomationProperties.AutomationId="ErrorMessagesInfoBar"
                    AutomationProperties.Name="Error messages"
                    CornerRadius="4"
                    IsClosable="True"
                    IsOpen="{Binding HasErrorMessages, Mode=OneWay}"
                    Severity="Error"
                    Title="Errors">
                    <ItemsControl ItemsSource="{Binding ErrorMessages}" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="WrapWholeWords" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </InfoBar>

                <InfoBar
                    AutomationProperties.AutomationId="WarningMessagesInfoBar"
                    AutomationProperties.Name="Warning messages"
                    CornerRadius="4"
                    IsClosable="True"
                    IsOpen="{Binding HasWarningMessages, Mode=OneWay}"
                    Severity="Warning"
                    Title="Warnings">
                    <ItemsControl ItemsSource="{Binding WarningMessages}" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="WrapWholeWords" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </InfoBar>

                <InfoBar
                    AutomationProperties.AutomationId="InformationMessagesInfoBar"
                    AutomationProperties.Name="Information messages"
                    CornerRadius="4"
                    IsClosable="True"
                    IsOpen="{Binding HasInformationMessages, Mode=OneWay}"
                    Severity="Informational"
                    Title="Information">
                    <ItemsControl ItemsSource="{Binding InformationMessages}" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="WrapWholeWords" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </InfoBar>
            </StackPanel>
        </Grid>
    </Border>
</Window>
